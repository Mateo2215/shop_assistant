# Firebase Web API key from the Firebase web app config.
# Required: yes
VITE_FIREBASE_API_KEY=your_firebase_api_key

# Firebase Auth domain, usually <project-id>.firebaseapp.com.
# Required: yes
VITE_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com

# Firebase project ID.
# Required: yes
VITE_FIREBASE_PROJECT_ID=your_project_id

# Firebase storage bucket from the Firebase web app config.
# Required: yes
VITE_FIREBASE_STORAGE_BUCKET=your_project.appspot.com

# Firebase messaging sender ID from the Firebase web app config.
# Required: yes
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id

# Firebase app ID from the Firebase web app config.
# Required: yes
VITE_FIREBASE_APP_ID=your_app_id

# Private household document ID used by the app.
# Required: yes
VITE_HOUSEHOLD_ID=your_household_id
